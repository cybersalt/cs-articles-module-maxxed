    <updateservers>
        <server type="extension" priority="1" name="Cybersalt Articles Module Maxxed Updates">https://raw.githubusercontent.com/cybersalt/cs-articles-module-maxxed/main/updates.xml</server>
    </updateservers>

    <config>
        <fields name="params">
            <fieldset name="basic" label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELDSET_BASIC_LABEL">
                <field
                    name="targets"
                    type="checkboxes"
                    label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_TARGETS_LABEL"
                    description="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_TARGETS_DESC"
                    default="mod_articles,mod_articles_category,mod_articles_latest"
                >
                    <option value="mod_articles">PLG_SYSTEM_CSARTICLESMODULEMAXXED_TARGET_MOD_ARTICLES</option>
                    <option value="mod_articles_category">PLG_SYSTEM_CSARTICLESMODULEMAXXED_TARGET_MOD_ARTICLES_CATEGORY</option>
                    <option value="mod_articles_latest">PLG_SYSTEM_CSARTICLESMODULEMAXXED_TARGET_MOD_ARTICLES_LATEST</option>
                </field>

                <field
                    name="notify_on_joomla_update"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_NOTIFY_LABEL"
                    description="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_NOTIFY_DESC"
                    default="1"
                    filter="integer"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <!-- Internal: last seen Joomla short version. Hidden field so it survives the
                     admin form save (Joomla's filter strips unknown params on save). -->
                <field
                    name="last_seen_joomla"
                    type="hidden"
                    default=""
                    filter="string"
                />
            </fieldset>

            <fieldset name="support" label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELDSET_SUPPORT_LABEL">
                <field
                    name="support_email"
                    type="email"
                    label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_EMAIL_LABEL"
                    description="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_EMAIL_DESC"
                    default="support@cybersalt.com"
                    filter="string"
                />

                <field
                    name="support_url"
                    type="url"
                    label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_URL_LABEL"
                    description="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_URL_DESC"
                    default="https://cybersalt.com"
                    filter="url"
                />

                <field
                    name="support_label"
                    type="text"
                    label="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_LABEL_LABEL"
                    description="PLG_SYSTEM_CSARTICLESMODULEMAXXED_FIELD_SUPPORT_LABEL_DESC"
                    default="Cybersalt support"
                    filter="string"
                />
            </fieldset>
        </fields>
    </config>
</extension>
