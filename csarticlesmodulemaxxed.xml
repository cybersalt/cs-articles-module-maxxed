        <language tag="pl-PL">language/pl-PL/plg_system_csarticlesmodulemaxxed.ini</language>
        <language tag="pl-PL">language/pl-PL/plg_system_csarticlesmodulemaxxed.sys.ini</language>
        <language tag="ja-JP">language/ja-JP/plg_system_csarticlesmodulemaxxed.ini</language>
        <language tag="ja-JP">language/ja-JP/plg_system_csarticlesmodulemaxxed.sys.ini</language>
